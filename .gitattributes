# Auto-detect text files and normalize them in Git.
* text=auto

# C# / .NET source files
*.cs text eol=crlf
*.csproj text eol=crlf
*.sln text eol=crlf
*.props text eol=crlf
*.targets text eol=crlf

# Config / data files
*.json text eol=crlf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=crlf
*.md text eol=crlf
*.txt text eol=crlf

# Scripts
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
*.sh text eol=lf

# Images and binaries
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.dll binary
*.exe binary
*.pdb binary
*.zip binary